{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/index.js",
    "create-admin": "node scripts/create-admin.js",
    "test": "set NODE_ENV=test&& vitest run --coverage && node scripts/print-coverage-summary.mjs",
    "test:coverage": "npm run test",
    "test:watch": "vitest",
    "sonar": "sonar-scanner",
    "test:sonar": "npm run test && npm run sonar",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:full": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^7.0.13",
    "pg": "^8.18.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "nodemon": "^3.1.10",
    "supertest": "^7.2.2",
    "vitest": "^4.0.18"
  }
}
