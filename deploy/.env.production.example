# Respaldo de PostgreSQL
# El script guarda el dump en una carpeta local sincronizada con Google Drive for desktop.
# Si no defines BACKUP_DIR, usa tmp/backups dentro del repo.
# BACKUP_DIR=G:\Mi unidad\Backup Assetcontrol
# BACKUP_ENV_FILE=deploy/.env.production
# PG_DUMP_PATH=C:\Program Files\PostgreSQL\16\bin\pg_dump.exe
